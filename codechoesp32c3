// ===== BLUETOOTH CALLBACKS =====
class MyServerCallbacks: public BLEServerCallbacks { void onDisconnect(BLEServer* pServer) { if (btOn && pAdvertising != NULL) { pAdvertising->start(); btStartTime = millis(); } } };
class MyBLE : public BLECharacteristicCallbacks { void onWrite(BLECharacteristic *pC) { String v = pC->getValue(); int y,mo,d,h,mi,s; if (sscanf(v.c_str(), "SYNC_TIME:%d,%d,%d,%d,%d,%d", &y,&mo,&d,&h,&mi,&s) == 6) { struct tm t = {s, mi, h, d, mo-1, y-1900}; time_t tt = mktime(&t); struct timeval tv = {tt, 0}; settimeofday(&tv, NULL); timeSynced = true; beep(100); forceRedraw = true; } } };

void setup() {
    pref.begin("bmo", false);
    btOn = true; 
    autoSleepOn = pref.getBool("s", false); macroAction = pref.getInt("mac", 0); 
    pomoWork = pref.getInt("pw", 25); pomoBreak = pref.getInt("pb", 5); timerSetMin = pref.getInt("tm", 5); 
    alarmHour = pref.getInt("aH", 0); alarmMin = pref.getInt("aM", 0); alarmRepeat = pref.getBool("aR", false); alarmActive = pref.getBool("aA", false);

    pinMode(BUZZER_PIN, OUTPUT); digitalWrite(BUZZER_PIN, LOW);
    bL.init(); bM.init(); bR.init(); bS.init(); 
    
    // [TỐI ƯU CỰC MẠNH]: Tăng tốc độ giao tiếp màn hình lên 400kHz (Fast Mode)
    Wire.begin(SDA_PIN, SCL_PIN); 
    Wire.setClock(400000); 
    
    display.begin(SSD1306_SWITCHCAPVCC, 0x3C); dht.begin(); 
    
    display.ssd1306_command(SSD1306_SETCONTRAST); 
    display.ssd1306_command(255); 
    
    BLEDevice::init("BMO-ESP32"); pServer = BLEDevice::createServer(); pServer->setCallbacks(new MyServerCallbacks()); 
    BLEService *psv = pServer->createService(SERVICE_UUID);
    BLECharacteristic *pch = psv->createCharacteristic(CHARACTERISTIC_UUID, BLECharacteristic::PROPERTY_WRITE);
    pch->setCallbacks(new MyBLE()); psv->start();
    
    pAdvertising = BLEDevice::getAdvertising(); pAdvertising->addServiceUUID(SERVICE_UUID);
    pAdvertising->setScanResponse(true); pAdvertising->setMinPreferred(0x06); pAdvertising->setMinPreferred(0x12);
    
    if(btOn) { pAdvertising->start(); btStartTime = millis(); }

    for(int i=0; i<40; i++) { stars[i].x = random(128); stars[i].y = random(64); }

    display.clearDisplay(); display.setTextColor(SSD1306_WHITE); display.setTextWrap(false);
    display.setTextSize(2); display.setCursor(46, 17); display.println("BMO");
    display.setTextSize(1); display.setCursor(33, 39); display.println("by phuc v.1");
    display.display();

    delay(2000);

    for (int i = 255; i >= 0; i -= 15) { display.ssd1306_command(SSD1306_SETCONTRAST); display.ssd1306_command(i); delay(40); }
    display.clearDisplay(); display.display();
    applyBrightness(1); delay(200); 

    display.setTextSize(2); display.setCursor(47, 25); display.println("> -"); display.display();
    digitalWrite(BUZZER_PIN, HIGH); delay(80); digitalWrite(BUZZER_PIN, LOW);
    delay(100);
    digitalWrite(BUZZER_PIN, HIGH); delay(120); digitalWrite(BUZZER_PIN, LOW);
    delay(800); 
}

// ===== VÒNG LẶP CHÍNH =====
void loop() {
    handleBuzzer(); unsigned long currentMillis = millis();

    static int currentMinuteTracker = -1;
    if (timeSynced) {
        struct tm ti; getLocalTime(&ti);
        if (ti.tm_min != currentMinuteTracker) {
            currentMinuteTracker = ti.tm_min;
            // [CẬP NHẬT TỐI ƯU]: Chỉ ép vẽ lại màn hình đồng hồ khi phút thay đổi
            if (uiState == STATE_CLOCK) forceRedraw = true;
            
            if (alarmActive && !alarmRinging && ti.tm_hour == alarmHour && ti.tm_min == alarmMin) {
                alarmRinging = true;
                if (!alarmRepeat) { alarmActive = false; pref.putBool("aA", false); }
            }
        }
    }

    if (uiState < STATE_GAMES_MENU && uiState != STATE_BMO_FACE) {
        bool shouldInvert = (currentMillis > 1800000UL) && ((currentMillis % 1800000UL) < 60000UL);
        if (shouldInvert != isInvertedMode && !alarmRinging) { isInvertedMode = shouldInvert; display.invertDisplay(isInvertedMode); }
        
        if (currentMillis - lastShiftTime > 30000UL) {
            int newX, newY; bool valid;
            do { valid = true; newX = random(-2, 3); newY = random(-2, 3); if (newX == prevX[0] && newY == prevY[0]) valid = false; if (newX == prevX[1] && newY == prevY[1]) valid = false; } while (!valid);
            prevX[1] = prevX[0]; prevY[1] = prevY[0]; prevX[0] = newX; prevY[0] = newY; shiftX = newX; shiftY = newY; lastShiftTime = currentMillis; if (uiState == STATE_CLOCK) forceRedraw = true;
        }

        if (btOn && (currentMillis - btStartTime > BT_TIMEOUT)) { if (pServer != NULL && pServer->getConnectedCount() == 0) { btOn = false; if (pAdvertising != NULL) pAdvertising->stop(); forceRedraw = true; } }
        
        if (currentMillis - lastDhtRead > 3000 || lastDhtRead == 0) {
            float t = dht.readTemperature(); float h = dht.readHumidity();
            if (!isnan(t) && !isnan(h)) { temp = round(t * 10.0) / 10.0; humi = round(h * 10.0) / 10.0; } lastDhtRead = currentMillis; forceRedraw = true;
        }
    }

    if (uiState < STATE_GAMES_MENU || uiState == STATE_SLEEP) {
        if (currentMillis - lastLightRead > 1500 || lastLightRead == 0) {
            volt = round((analogRead(LIGHT_PIN) * (3.3 / 4095.0)) * 10.0) / 10.0; 
            lastLightRead = currentMillis; 
            
            int newBright = 1; 
            if (volt < 0.05) newBright = 0; 
            else if (volt >= 2.0) newBright = 2; 
            
            if (newBright != currentAutoBright && uiState != STATE_SLEEP) {
                currentAutoBright = newBright; applyBrightness(currentAutoBright);
            }

            if (volt < 0.05) { 
                if (!isDark) { isDark = true; darkStartTime = currentMillis; }
                else if (currentMillis - darkStartTime > 60000UL) { 
                    if (!(uiState == STATE_BMO_FACE && isSnoring) && uiState != STATE_SLEEP) {
                        uiState = STATE_BMO_FACE; isSnoring = true; isUwU = false;
                        zzzY[0] = 50; zzzX[0] = 60; zzzY[1] = 40; zzzX[1] = 68; zzzY[2] = 30; zzzX[2] = 75;
                        forceRedraw = true;
                    }
                }
            } else {
                isDark = false;
                if (volt > 0.1 && !manualSleepOverride) {
                    if ((uiState == STATE_BMO_FACE && isSnoring) || uiState == STATE_SLEEP) {
                        if (uiState == STATE_SLEEP) display.ssd1306_command(0xAF); 
                        uiState = STATE_CLOCK; isSnoring = false; beep(50); 
                        lastInteract = currentMillis; forceRedraw = true;
                    }
                }
            }
            if (uiState == STATE_LIGHT || uiState == STATE_ART) forceRedraw = true;
        }
    }

    int sL = bL.check(), sM = bM.check(), sR = bR.check(), sS = bS.check();
    bool rawL = digitalRead(BTN_L);
    bool rawR = digitalRead(BTN_R);

    if (uiState == STATE_BMO_FACE && !isSnoring) {
        if (swipeState != 0 && (currentMillis - swipeStart > 1300)) swipeState = 0;
        if (sL == 1) { swipeState = 1; swipeStart = currentMillis; } 
        else if (sR == 1) { swipeState = 2; swipeStart = currentMillis; } 
        else if (sM == 1) {
            if (swipeState == 1 || swipeState == 2) { isUwU = true; uwuTimer = currentMillis; swipeState = 0; beep(80); }
        }
    }

    if (sL || sM || sR || sS) { 
        manualSleepOverride = false; lastInteract = currentMillis; darkStartTime = currentMillis; forceRedraw = true; 
        if (uiState == STATE_SLEEP) { uiState = STATE_CLOCK; display.ssd1306_command(0xAF); pendingSleepMacro = false; beep(50); return; }
        if (alarmRinging) { alarmRinging = false; display.invertDisplay(isInvertedMode); digitalWrite(BUZZER_PIN, LOW); beep(50); return; } 
        if (isSnoring) { isSnoring = false; beep(60); return; } 
    }

    if (sS == 1) {
        if (uiState == STATE_STOPWATCH) { isSwRunning = false; swElapsedTime = 0; } 
        
        if (pendingSleepMacro) { 
            pendingSleepMacro = false; manualSleepOverride = true; uiState = STATE_SLEEP; display.ssd1306_command(0xAE); return; 
        }
        else if (uiState >= STATE_BMO_FACE) { uiState = STATE_CLOCK; } 
        else {
            if (macroAction == 1) { uiState = STATE_POMO; }
            else if (macroAction == 2) { uiState = STATE_ART; }
            else if (macroAction == 3) { uiState = STATE_ALARM; } 
            else if (macroAction == 4) { pendingSleepMacro = true; forceRedraw = true; return; } 
            else if (macroAction == 5) { uiState = STATE_GAMES_MENU; gameIdx = 0; }
            else if (macroAction == 6) { uiState = STATE_BMO_FACE; } 
        }
    }
    if (pendingSleepMacro && (sL || sM || sR)) { pendingSleepMacro = false; forceRedraw = true; return; }
    if (uiState == STATE_MENU && (currentMillis - lastInteract > MENU_TIMEOUT)) { uiState = STATE_CLOCK; forceRedraw = true; }

    if (sM == 2) { 
        if (uiState == STATE_STOPWATCH) { isSwRunning = false; swElapsedTime = 0; } 
        if (uiState == STATE_CLOCK) { }
        else if (uiState == STATE_MENU) uiState = STATE_CLOCK;
        else if (uiState >= STATE_TREX && uiState <= STATE_PONG) { uiState = STATE_GAMES_MENU; }
        else { uiState = STATE_MENU; isPomoRunning = false; isPomoPaused = false; pomoWaitingNext = false; isTimerRunning = false; settingMode = 0; } 
        return; 
    }

    switch (uiState) {
        case STATE_CLOCK:
            if (sL || sM || sR) uiState = STATE_MENU; break;
        case STATE_MENU:
            if (sL == 1) menuIdx = (menuIdx + 9) % 10; 
            if (sR == 1) menuIdx = (menuIdx + 1) % 10;
            if (sM == 1) { uiState = (UIState)(STATE_ENV + menuIdx); settingMode = 0; } break;
            
        case STATE_POMO: 
            if (!isPomoRunning && !pomoWaitingNext) {
                if (sM == 1) pomoEditIdx = (pomoEditIdx + 1) % 3;
                if (pomoEditIdx == 0) { if (sL == 1 && pomoWork>1) pomoWork--; if (sR == 1 && pomoWork<99) pomoWork++; }
                else if (pomoEditIdx == 1) { if (sL == 1 && pomoBreak>1) pomoBreak--; if (sR == 1 && pomoBreak<99) pomoBreak++; }
                else if (pomoEditIdx == 2 && sM == 1) { 
                    isPomoRunning = true; isPomoPaused = false; pomoWaitingNext = false; isBreakTime = false; 
                    pomoCurrentSec = pomoWork * 60; pomoStartTime = currentMillis; 
                    pref.putInt("pw", pomoWork); pref.putInt("pb", pomoBreak); 
                }
            } else if (pomoWaitingNext) {
                if (sL == 1 || sR == 1 || sM == 1) { pomoWaitingNext = false; isPomoRunning = true; isPomoPaused = false; pomoStartTime = currentMillis; }
            } else {
                if (sM == 1) { isPomoPaused = !isPomoPaused; if (!isPomoPaused) pomoStartTime = currentMillis; forceRedraw = true; }
                if (!isPomoPaused) {
                    if (currentMillis - pomoStartTime >= 1000) { pomoCurrentSec--; pomoStartTime = currentMillis; forceRedraw = true; }
                    if (pomoCurrentSec <= 0) { 
                        alarmRinging = true; isPomoRunning = false; pomoWaitingNext = true; 
                        isBreakTime = !isBreakTime; pomoCurrentSec = (isBreakTime ? pomoBreak : pomoWork) * 60; 
                        forceRedraw = true;
                    }
                }
            } break;
            
        case STATE_TIMER:
            if (!isTimerRunning) {
                if (sL == 1 && timerSetMin > 1) timerSetMin--; if (sR == 1 && timerSetMin < 99) timerSetMin++;
                if (sM == 1) { isTimerRunning = true; timerSec = timerSetMin * 60; timerStartTime = currentMillis; pref.putInt("tm", timerSetMin); }
            } else {
                if (currentMillis - timerStartTime >= 1000) { timerSec--; timerStartTime = currentMillis; forceRedraw = true; }
                if (sM == 1) isTimerRunning = false; if (timerSec <= 0) { isTimerRunning = false; alarmRinging = true; } 
            } break;
            
        case STATE_SETTINGS:
            if (settingMode == 0) {
                if (sL == 1) settingCursor = (settingCursor + 3) % 4;
                if (sR == 1) settingCursor = (settingCursor + 1) % 4;
                if (sM == 1) { 
                    if (settingCursor == 3) { uiState = STATE_MENU; settingCursor = 0; } 
                    else { settingMode = 1; tempBtOn = btOn; tempSleepOn = autoSleepOn; tempMacro = macroAction; } 
                }
            } 
            else if (settingMode == 1) {
                if (sL == 1 || sR == 1) {
                    if (settingCursor == 0) tempBtOn = !tempBtOn;
                    if (settingCursor == 1) tempSleepOn = !tempSleepOn;
                    if (settingCursor == 2) { if (sL == 1) tempMacro = (tempMacro + 6) % 7; if (sR == 1) tempMacro = (tempMacro + 1) % 7; } 
                }
                if (sM == 1) settingMode = 2; 
            }
            else if (settingMode == 2) {
                if (sL == 1) { settingMode = 0; } 
                if (sR == 1) { 
                    btOn = tempBtOn; autoSleepOn = tempSleepOn; macroAction = tempMacro;
                    pref.putBool("b", btOn); pref.putBool("s", autoSleepOn); pref.putInt("mac", macroAction);
                    if (settingCursor == 0) { if(btOn && pAdvertising != NULL) { pAdvertising->start(); btStartTime = currentMillis; } else if (pAdvertising != NULL) pAdvertising->stop(); }
                    settingMode = 0; 
                }
            } break;

        case STATE_BMO_FACE:
            if (currentMillis - lastBmoTick > 30) {
                if (isSnoring) {
                    targetOffsetX = 0; targetOffsetY = round(sin(currentMillis / 1000.0) * 4 * 10.0) / 10.0; 
                    for(int i=0; i<3; i++) {
                        zzzY[i] -= (i==1 ? 0.8 : 0.5); zzzX[i] += sin(zzzY[i]*0.1) * 0.5; 
                        if (zzzY[i] < -10) { zzzY[i] = random(55, 65); zzzX[i] = 64 + random(-15, 15); }
                    }
                } 
                else if (isUwU) {
                    targetOffsetX = 0; targetOffsetY = 0; 
                    if (currentMillis - uwuTimer > 3000) isUwU = false;
                } 
                else {
                    if (currentMillis - lastBlinkTime > 4000 && blinkState == 0) { blinkState = 1; lastBlinkTime = currentMillis; } 
                    else if (currentMillis - lastBlinkTime > 150 && blinkState == 1) { blinkState = 0; lastBlinkTime = currentMillis; }
                    
                    if (currentMillis - moveTime > random(1500, 3000) && blinkState == 0) {
                        int movementType = random(0, 8);
                        if (movementType == 0) { targetOffsetX = -10; targetOffsetY = 0; } else if (movementType == 1) { targetOffsetX = 10; targetOffsetY = 0; } else if (movementType == 2) { targetOffsetX = -10; targetOffsetY = -8; } else if (movementType == 3) { targetOffsetX = 10; targetOffsetY = -8; } else if (movementType == 4) { targetOffsetX = -10; targetOffsetY = 8; } else if (movementType == 5) { targetOffsetX = 10; targetOffsetY = 8; } else { targetOffsetX = 0; targetOffsetY = 0; }
                        moveTime = currentMillis;
                    }
                }
                bmoOffsetX += (targetOffsetX - bmoOffsetX) / 2; bmoOffsetY += (targetOffsetY - bmoOffsetY) / 2;
                forceRedraw = true; lastBmoTick = currentMillis;
            } break;
            
        case STATE_GAMES_MENU:
            if (sL == 1) gameIdx = (gameIdx + 2) % 3;
            if (sR == 1) gameIdx = (gameIdx + 1) % 3;
            if (sM == 1) { if (gameIdx == 0) initTRex(); else if (gameIdx == 1) initSpace(); else initPong(); }
            break;

        case STATE_ALARM:
            if (!alarmActive) {
                if (alarmEditIdx < 3) {
                    if (sM == 1) alarmEditIdx++;
                    else if (alarmEditIdx == 0) { if (sL == 1) alarmHour = (alarmHour + 23) % 24; if (sR == 1) alarmHour = (alarmHour + 1) % 24; }
                    else if (alarmEditIdx == 1) { if (sL == 1) alarmMin = (alarmMin + 59) % 60; if (sR == 1) alarmMin = (alarmMin + 1) % 60; }
                } else if (alarmEditIdx == 3) {
                    if (sL == 1 || sR == 1) {
                        alarmRepeat = (sL == 1); alarmActive = true; alarmEditIdx = 0; 
                        pref.putInt("aH", alarmHour); pref.putInt("aM", alarmMin); pref.putBool("aR", alarmRepeat); pref.putBool("aA", alarmActive);
                    } else if (sM == 1) { alarmEditIdx = 0; } 
                }
            } else {
                if (sM == 1) { alarmActive = false; pref.putBool("aA", false); } 
            } break;

        case STATE_STOPWATCH:
            if (sM == 1) {
                isSwRunning = !isSwRunning;
                if (isSwRunning) swStartTime = currentMillis - swElapsedTime;
                else swElapsedTime = currentMillis - swStartTime;
            }
            if (!isSwRunning && (sL == 1 || sR == 1)) { swElapsedTime = 0; forceRedraw = true;}
            break;

        case STATE_TREX:
            if (sM == 1 && !trexGameOver && dinoY == 44) { dinoVy = -8; beep(10); }
            if ((sL == 1 || sR == 1) && trexGameOver) initTRex();
            if (currentMillis - lastGameTick > 40) {
                if (!trexGameOver) {
                    dinoVy += 0.8; dinoY += dinoVy; 
                    if (dinoY >= 44) { dinoY = 44; dinoVy = 0; } 
                    cactusX -= 3;
                    if (cactusX < -5) { cactusX = 128; trexScore++; }
                    if (cactusX < 20 && cactusX > 5 && dinoY > 34) { trexGameOver = true; beep(150); }
                }
                forceRedraw = true; lastGameTick = currentMillis;
            } break;

        case STATE_SPACE: {
            bool spaceWon = true; for(int i=0; i<12; i++) if(aliens[i]) spaceWon = false;
            if (sM == 1 && !spaceGameOver && !spaceWon && !bulletActive) { bulletActive = true; bulletX = shipX; bulletY = 55; beep(10); }
            if ((sL == 1 || sR == 1) && (spaceGameOver || spaceWon)) initSpace();
            if (currentMillis - lastGameTick > 40) {
                if (!spaceGameOver && !spaceWon) {
                    if (rawL && shipX > 5) shipX -= 3; 
                    if (rawR && shipX < 123) shipX += 3;
                    if (bulletActive) {
                        bulletY -= 4; if (bulletY < 0) bulletActive = false;
                        for (int i=0; i<12; i++) {
                            if (aliens[i]) {
                                int ax = alienBaseX + (i%4)*20; int ay = alienBaseY + (i/4)*12;
                                if (bulletX > ax-2 && bulletX < ax+10 && bulletY > ay && bulletY < ay+8) { aliens[i] = 0; bulletActive = false; beep(20); break; }
                            }
                        }
                    }
                    alienBaseX += alienDir; if (alienBaseX > 45 || alienBaseX < 2) { alienDir = -alienDir; alienBaseY += 2; }
                    if (alienBaseY > 35) { spaceGameOver = true; beep(150); } 
                }
                forceRedraw = true; lastGameTick = currentMillis;
            } break;
        }

        case STATE_PONG: {
            bool pongWon = true; for(int i=0; i<15; i++) if(bricks[i]) pongWon = false;
            if ((sL == 1 || sR == 1) && (pongGameOver || pongWon)) initPong();
            if (currentMillis - lastGameTick > 40) {
                if (!pongGameOver && !pongWon) {
                    if (rawL && paddleX > 0) paddleX -= 4; 
                    if (rawR && paddleX < 108) paddleX += 4;
                    ballX += ballDx; ballY += ballDy;
                    if (ballX <= 0 || ballX >= 125) { ballDx = -ballDx; beep(10); } 
                    if (ballY <= 0) { ballDy = -ballDy; beep(10); } 
                    if (ballY >= 56 && ballX >= paddleX && ballX <= paddleX + 20) { ballDy = -abs(ballDy); beep(10); }
                    if (ballY > 64) { pongGameOver = true; beep(150); } 
                    for(int i=0; i<15; i++) {
                        if (bricks[i]) {
                            int bx = (i%5)*25 + 2; int by = (i/5)*8 + 12; 
                            if (ballX > bx && ballX < bx+23 && ballY > by && ballY < by+6) { bricks[i] = 0; ballDy = -ballDy; pongScore++; beep(20); break; }
                        }
                    }
                }
                forceRedraw = true; lastGameTick = currentMillis;
            } break;
        }
        case STATE_SLEEP: break;
    }

    if (autoSleepOn && uiState != STATE_BMO_FACE && uiState != STATE_SLEEP && uiState < STATE_TREX && uiState != STATE_GAMES_MENU && !(uiState == STATE_STOPWATCH && isSwRunning) && (currentMillis - lastInteract > SLEEP_TIMEOUT)) { 
        manualSleepOverride = true; 
        uiState = STATE_SLEEP; display.ssd1306_command(0xAE); 
    }
    
    // [CẬP NHẬT TỐI ƯU]: Chỉ kết xuất tự động (Auto-Render) khi Màn hình sao hoặc Bấm giờ đang chạy
    bool needAutoFrame = (uiState == STATE_ART || (uiState == STATE_STOPWATCH && isSwRunning));
    
    if (forceRedraw || (needAutoFrame && (currentMillis - lastFrameTime > 40))) {
        if (uiState != STATE_SLEEP && !alarmRinging) renderUI(); 
        lastFrameTime = currentMillis; forceRedraw = false;
    }
}
