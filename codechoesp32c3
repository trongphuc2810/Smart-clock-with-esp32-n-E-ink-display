    display.setCursor((128 - w) / 2, y); display.print(txt);
}

// ===== LỚP XỬ LÝ NÚT CHẠM =====
class TouchButton {
    uint8_t p; bool ls, ip, longTriggered; unsigned long ps, lastRepeat; bool useLong;
public:
    TouchButton(uint8_t pin, bool hasLong) : p(pin), ls(false), ip(false), longTriggered(false), ps(0), lastRepeat(0), useLong(hasLong) {}
    void init() { pinMode(p, INPUT); }
    int check() {
        if (millis() < 2000) return 0; 
        int res = 0; bool r = digitalRead(p);
        if (r && ls && ip && (millis() - ps > 12000)) return 0; 
        if (r && !ls) { ps = millis(); lastRepeat = millis(); ip = true; longTriggered = false; if (!useLong) res = 1; beep(20); }
        if (r && ls && ip) { 
            if (useLong) { if (!longTriggered && (millis() - ps > 800)) { longTriggered = true; res = 2; beep(50); } } 
            else { if (millis() - ps > 500) { if (millis() - lastRepeat > 120) { lastRepeat = millis(); res = 1; beep(10); } } }
        }
        if (!r && ls) { if (ip && useLong && !longTriggered) res = 1; ip = false; }
        ls = r; return res;
    }
};

TouchButton bL(BTN_L, false), bM(BTN_M, true), bR(BTN_R, false), bS(BTN_S, false);

